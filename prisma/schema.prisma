// GSE Control - Prisma schema (za Demo Mode)
// Production koristi Supabase (vidi supabase/migrations/)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Employee {
  id          String   @id @default(cuid())
  cardId      String   @unique
  name        String
  department  String   @default("Ramp")
  role        String   @default("Operator")
  active      Boolean  @default(true)
  pin         String?  // 4-digit PIN for no-login worker identification
  idCardQr    String?  // QR kod na ID kartici
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignments     Assignment[]
  damages         DamageReport[]
  qualifications  EquipmentQualification[]
}

model Equipment {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  type          String
  serialNumber  String?
  location      String   @default("Stand A1")
  status        String   @default("AVAILABLE")
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // ADR.OPS.C.007 - Vehicle Fitness Certificate
  fitnessStatus       String?  // FIT | UNFIT | CONDITIONAL (auto-calculated)
  fitnessCalculatedAt DateTime?
  fitnessReason       String?  // why it's unfit/conditional

  // Vehicle Operating Manual (Part-145 §65)
  manualUrl           String?  // direct link to PDF manual

  // Access Control - admin može ograničiti ko može zadužiti sredstvo
  restrictedAccess    Boolean  @default(false) // ako je true, samo autorizovani radnici mogu zadužiti

  // Periodic inspections (IATA AHM 1130)
  lastInspectionDate     DateTime?
  nextInspectionDate     DateTime?
  inspectionIntervalMonths Int   @default(12)

  // Operating hours (EASA Part-M continued airworthiness)
  totalOperatingHours       Float @default(0)
  maintenanceIntervalHours  Float @default(500)
  lastMaintenanceHours      Float @default(0)

  // Lifecycle info
  manufacturer          String?
  modelYear             Int?
  purchaseDate          DateTime?
  warrantyExpiry        DateTime?
  registrationNumber    String?

  assignments   Assignment[]
  damages       DamageReport[]
  maintenanceLogs MaintenanceLog[]
  photos        EquipmentPhoto[]

  @@index([status])
  @@index([type])
  @@index([nextInspectionDate])
}

model Assignment {
  id                String   @id @default(cuid())
  equipmentId       String
  equipmentCode     String
  equipmentName     String
  employeeId        String?
  employeeCardId    String
  employeeName      String

  action            String
  inspectionResult  String
  inspectionNotes   String?
  checklistJson     String

  shift             String?
  damageReportId    String?

  timestamp         DateTime @default(now())

  equipment         Equipment @relation(fields: [equipmentId], references: [id])
  employee          Employee? @relation(fields: [employeeId], references: [id])

  @@index([equipmentId])
  @@index([employeeCardId])
  @@index([action])
  @@index([timestamp])
}

model DamageReport {
  id            String    @id @default(cuid())
  equipmentId   String
  equipmentCode String
  equipmentName String

  reportedByCardId String
  reportedByName   String
  employeeId       String?

  severity      String    @default("MINOR")
  description   String
  status        String    @default("OPEN")
  resolution    String?
  resolvedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Root cause analysis (EASA Part-145)
  rootCause           String?
  correctiveAction    String?
  preventiveAction    String?
  insuranceClaimRef   String?
  estimatedCost       Float?

  equipment     Equipment @relation(fields: [equipmentId], references: [id])
  employee      Employee? @relation(fields: [employeeId], references: [id])
  photos        EquipmentPhoto[]

  @@index([status])
  @@index([equipmentId])
}

model MaintenanceLog {
  id            String   @id @default(cuid())
  equipmentId   String
  equipmentCode String
  equipmentName String

  maintenanceType String  // PREVENTIVE | CORRECTIVE | INSPECTION | OVERHAUL
  description   String
  performedBy   String?
  performedByCardId String?
  cost          Float?
  durationHours Float?
  operatingHoursAtService Float?

  certificateNumber String?
  partsReplaced String?
  nextDueHours  Float?
  nextDueDate   DateTime?

  status        String   @default("COMPLETED")

  performedAt   DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  equipment     Equipment @relation(fields: [equipmentId], references: [id])

  @@index([equipmentId])
  @@index([maintenanceType])
  @@index([performedAt])
}

model EquipmentPhoto {
  id            String   @id @default(cuid())
  damageReportId String?
  equipmentId   String?
  photoData     String   // base64 encoded
  photoType     String   @default("image/jpeg")
  caption       String?
  takenByCardId String?
  takenByName   String?
  takenAt       DateTime @default(now())

  damageReport  DamageReport? @relation(fields: [damageReportId], references: [id])
  equipment     Equipment?    @relation(fields: [equipmentId], references: [id])

  @@index([damageReportId])
  @@index([equipmentId])
}

model EquipmentQualification {
  id            String   @id @default(cuid())
  employeeId    String
  employeeCardId String
  employeeName  String
  equipmentType String
  qualificationLevel String @default("OPERATOR")
  trainedAt     DateTime?
  validUntil    DateTime?
  certifiedBy   String?
  certificateNumber String?
  createdAt     DateTime @default(now())

  employee      Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, equipmentType])
  @@index([employeeId])
  @@index([equipmentType])
}

model WebhookSetting {
  id            String   @id @default(cuid())
  name          String
  webhookUrl    String
  webhookType   String   @default("SLACK")
  enabled       Boolean  @default(true)
  triggerCriticalDamage     Boolean @default(true)
  triggerDamageResolved     Boolean @default(false)
  triggerOutOfService       Boolean @default(true)
  triggerInspectionOverdue  Boolean @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AuditLog {
  id            String   @id @default(cuid())
  userId        String?
  userEmail     String?
  userRole      String?
  action        String
  entityType    String?
  entityId      String?
  details       String?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model AppSetting {
  id                            Int      @id @default(1)
  airportName                   String   @default("Aerodrom")
  airportCode                   String   @default("XXX")
  timezone                      String   @default("Europe/Podgorica")
  language                      String   @default("hr")
  requirePhotoForDamage         Boolean  @default(false)
  requireQualificationForCheckout Boolean @default(true)
  enableEmailNotifications      Boolean  @default(true)
  enableWebhookNotifications    Boolean  @default(false)
  inspectionReminderDays        Int      @default(30)
  updatedAt                     DateTime @updatedAt
}

// =====================================================
// EASA Part-145 §50 - Life-limited components
// =====================================================
model EquipmentComponent {
  id                String   @id @default(cuid())
  equipmentId       String
  equipmentCode     String

  componentName     String
  componentType     String
  serialNumber      String?
  manufacturer      String?

  installedAt       DateTime?
  installedHours    Float    @default(0)
  lifeLimitHours    Float?
  lifeLimitCycles   Float?
  currentHours      Float    @default(0)
  currentCycles     Float    @default(0)

  status            String   @default("ACTIVE")

  replacedAt        DateTime?
  replacedBy        String?
  replacementCost   Float?

  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([equipmentId])
  @@index([status])
  @@index([componentType])
}

// =====================================================
// EASA Part-145 §71 - Service Bulletins
// =====================================================
model ServiceBulletin {
  id                String   @id @default(cuid())
  bulletinNumber    String   @unique
  title             String
  manufacturer      String

  equipmentType     String?
  serialRange       String?

  description       String
  requiredAction    String
  partsRequired     String?
  estimatedHours    Float?

  priority          String   @default("MEDIUM")
  complianceDeadline DateTime?
  status            String   @default("OPEN")

  issuedAt          DateTime
  completedAt       DateTime?
  completedBy       String?
  completionNotes   String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([status])
  @@index([manufacturer])
  @@index([priority])
}

// =====================================================
// EASA Part-M §39 - Airworthiness Directives
// =====================================================
model AirworthinessDirective {
  id                String   @id @default(cuid())
  adNumber          String   @unique
  title             String

  equipmentType     String?

  description       String
  requiredAction    String
  complianceMethod  String?

  priority          String   @default("HIGH")
  effectiveDate     DateTime
  complianceDeadline DateTime?
  recurring         Boolean  @default(false)
  recurringIntervalHours Float?

  status            String   @default("OPEN")

  compliedAt        DateTime?
  compliedBy        String?
  complianceNotes   String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([status])
  @@index([priority])
}

// =====================================================
// IATA AHM 340 - Shift Handovers
// =====================================================
model ShiftHandover {
  id                String   @id @default(cuid())
  shiftDate         DateTime
  shiftType         String

  outgoingCardId    String
  outgoingName      String
  outgoingSignature String?

  incomingCardId    String
  incomingName      String
  incomingSignature String?

  assignedEquipmentCount Int  @default(0)
  openDamagesCount       Int  @default(0)
  notes                  String?

  status            String   @default("COMPLETED")

  handoverAt        DateTime @default(now())
  createdAt         DateTime @default(now())

  @@index([shiftDate])
  @@index([outgoingCardId])
  @@index([incomingCardId])
}

// =====================================================
// ADR.OPS.C.007 - Maintenance Schedule (auto-generation)
// =====================================================
model MaintenanceSchedule {
  id                String   @id @default(cuid())
  equipmentId       String
  equipmentCode     String
  equipmentName     String

  maintenanceType   String   // PREVENTIVE | PERIODIC | ANNUAL | SCHEDULED
  title             String
  description       String?

  // Trigger criteria
  triggerHours      Float?   // at what operating hours
  triggerDate       DateTime? // or at what date
  triggerInterval   Float?   // recurring interval (hours)

  // Status
  status            String   @default("SCHEDULED") // SCHEDULED | DUE | IN_PROGRESS | COMPLETED | OVERDUE
  priority          String   @default("MEDIUM")    // LOW | MEDIUM | HIGH | CRITICAL

  // Completion
  completedAt       DateTime?
  completedBy       String?
  completionNotes   String?
  actualHours       Float?

  // Auto-generated
  autoGenerated     Boolean  @default(false)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([equipmentId])
  @@index([status])
  @@index([priority])
}

// =====================================================
// ADR.OPS.C.007 - Daily Inspection Record
// =====================================================
model DailyInspection {
  id                String   @id @default(cuid())
  equipmentId       String
  equipmentCode     String
  equipmentName     String

  // Inspector
  inspectorCardId   String
  inspectorName     String

  // Inspection date
  inspectionDate    DateTime @default(now())
  shift             String   // MORNING | AFTERNOON | NIGHT

  // Checklist (JSON: [{ id, label, passed }])
  checklistJson     String

  // Result
  result            String   // FIT | UNFIT | CONDITIONAL
  notes             String?

  // Issues found
  issuesFound       Int      @default(0)
  issuesJson        String?  // JSON array of issues

  createdAt         DateTime @default(now())

  @@index([equipmentId])
  @@index([inspectionDate])
  @@index([result])
}

// =====================================================
// EASA Part-145 §65 - Vehicle Operating Manuals
// =====================================================
model EquipmentManual {
  id              String   @id @default(cuid())
  equipmentId     String?  // null = generic manual for equipmentType
  equipmentCode   String?  // denormalized for display
  equipmentName   String?  // denormalized
  equipmentType   String   // TOW_TRACTOR, GPU, BELT_LOADER, etc.

  title           String   // npr. "Goldhofer AST-2 Operating Manual"
  manualUrl       String   // URL to PDF (Supabase Storage or external)
  manualType      String   @default("OPERATING") // OPERATING | MAINTENANCE | SAFETY | PARTS
  language        String   @default("hr") // hr | en | de | etc.
  fileSize        Int?     // bytes (optional)
  uploadedBy      String?
  version         String?  // npr. "v2.1"
  active          Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([equipmentId])
  @@index([equipmentType])
  @@index([manualType])
}

// =====================================================
// Equipment Access Control - ko može zadužiti koje sredstvo
// =====================================================
model EquipmentAccess {
  id              String   @id @default(cuid())
  equipmentId     String
  equipmentCode   String
  employeeCardId  String
  employeeName    String
  grantedBy       String?  // ko je dao dozvolu
  createdAt       DateTime @default(now())

  @@unique([equipmentId, employeeCardId])
  @@index([equipmentId])
  @@index([employeeCardId])
}
