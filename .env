# =====================================================
# GSE Control - Environment Variables
# =====================================================

# --- Local SQLite database (samo za Demo Mode) ---
# Koristi se kada NEXT_PUBLIC_SUPABASE_URL nije postavljen
DATABASE_URL="file:./db/custom.db"

# --- Supabase konfiguracija (Production) ---
# Kopiraj iz Supabase Dashboard > Project Settings > API
# Kada su ove postavljene, aplikacija radi u Production modu (koristi Supabase bazu i Auth)
# Kada NISU postavljene, aplikacija radi u Demo Mode (lokalna SQLite + hardcoded demo korisnici)

# NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...
# --- MOCK DATA MODE ---
# Postavite na "true" da koristite mock podatke (bez Supabase-a)
# - U development: koristi mock data za sve upite (radnici, oprema, login)
# - U production: postavite na "false" ili uklonite da koristi pravi Supabase
# Na Vercelu: Settings > Environment Variables > MOCK_DATA = false
MOCK_DATA=false

# --- Supabase konfiguracija (Production) ---
# Kopiraj iz Supabase Dashboard > Project Settings > API
# Kada su ove postavljene i MOCK_DATA=false, aplikacija koristi pravi Supabase

NEXT_PUBLIC_SUPABASE_URL=https://dipvaittxxfzjgkwacye.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_ZB7lS94fYqvtzr0r-Z-5eQ_OjGefK_5

# --- Custom domen (opciono) ---
# Ako koristite custom domen (npr. gse.aerodrom.me), postavite ovdje
# PRODUCTION_DOMAIN=gse.aerodrom.me
